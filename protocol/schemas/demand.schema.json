{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-delivery-loop.dev/schemas/demand.schema.json",
  "title": "Demand",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "agent.delivery.loop/v0" },
    "kind": { "const": "Demand" },
    "metadata": {
      "type": "object",
      "required": ["id", "title", "created_at"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "created_at": { "type": "string" }
      },
      "additionalProperties": true
    },
    "spec": {
      "type": "object",
      "required": ["requester", "request"],
      "properties": {
        "requester": { "$ref": "common.schema.json#/definitions/actorRef" },
        "request": { "type": "string", "minLength": 1 },
        "success_criteria": { "type": "array", "items": { "type": "string" } },
        "budget": { "$ref": "budget.schema.json" },
        "permissions": { "$ref": "common.schema.json#/definitions/permissionSet" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
